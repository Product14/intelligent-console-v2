        "./vendor-settings/design-system/graph/area-graph.jsx"
      ],
      "@spyne-console/design-system/graph/gauge": [
        "./vendor-settings/design-system/graph/gauge/gauge.jsx"
      ],
      "@spyne-console/design-system/divider": [
        "./vendor-settings/design-system/divider/divider.jsx"
      ],
      "@spyne-console/design-system/charts": [
        "./vendor-settings/design-system/charts/charts.jsx"
      ],
      "@spyne-console/design-system/charts/doughnut-chart": [
        "./vendor-settings/design-system/charts/doughnut-chart.jsx"
      ],
      "@spyne-console/design-system/bottom-mobile-drawer": [
        "./vendor-settings/design-system/mobile-drawer/bottom-mobile-drawer.jsx"
      ],
      "@spyne-console/design-system/text-area": [
        "./vendor-settings/design-system/text-area/text-area.jsx"
      ],
      "@spyne-console/design-system/select-chip": [
        "./vendor-settings/design-system/select-chip/select-chip.jsx"
      ],
      "@spyne-console/design-system/svg": [
        "./vendor-settings/design-system/icons/svg/SVG.js"
      ],
      "@spyne-console/design-system/bottom-popup": [
        "./vendor-settings/design-system/bottom-popup/bottom-popup.jsx"
      ],
      "@spyne-console/design-system/charts/bar-graph": [
        "./vendor-settings/design-system/charts/bar-graph.jsx"
      ],
      "@spyne-console/design-system/charts/pie-chart-with-customized-label": [
        "./vendor-settings/design-system/charts/pie-chart-with-customized-label.jsx"
      ],
      "@spyne-console/design-system/charts/horizontal-bar-chart": [
        "./vendor-settings/design-system/charts/horizontal-bar-chart.jsx"
      ],
      "@spyne-console/design-system/three-dot-menu": [
        "./vendor-settings/design-system/three-dot-vertical-menu-popup/three-dot-menu.jsx"
      ],
      "@spyne-console/design-system/tooltip-v2": [
        "./vendor-settings/design-system/tooltip/tooltip-v2.jsx"
      ],
      "@spyne-console/design-system/info-banner": [
