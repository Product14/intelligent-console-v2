      ],
      "@spyne-console/design-system/options-popup": [
        "./vendor-settings/design-system/options-popup/options-popup.jsx"
      ],
      "@spyne-console/design-system/*": [
        "./vendor-settings/design-system/*"
      ],
      "@spyne-console/components": [
        "./vendor-settings/components/index.js"
      ],
      "@spyne-console/components/*": [
        "./vendor-settings/components/*"
      ],
      "@spyne-console/utils": [
        "./vendor-settings/utils-shim.ts"
      ],
      "@spyne-console/utils/cn": [
        "./vendor-settings/utils/cn.js"
      ],
      "@spyne-console/utils/centralAPIHandler": [
        "./lib/settings/api/http.ts"
      ],
      "@spyne-console/utils/*": [
        "./vendor-settings/utils/*"
      ],
      "@spyne-console/hooks": [
        "./vendor-settings/hooks/index.js"
      ],
      "@spyne-console/hooks/*": [
        "./vendor-settings/hooks/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
