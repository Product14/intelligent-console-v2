      ],
      "@spyne-console/design-system/dropdown/radio-dropdown": [
        "./vendor-settings/design-system/dropdown/radio-dropdown/radio-dropdown.jsx"
      ],
      "@spyne-console/design-system/dropdown-wrapper": [
        "./vendor-settings/design-system/dropdown/dropdown-wrapper.jsx"
      ],
      "@spyne-console/design-system/badge": [
        "./vendor-settings/design-system/badge/badge.jsx"
      ],
      "@spyne-console/design-system/badge/media-status-badge": [
        "./vendor-settings/design-system/badge/media-status-badge/index.jsx"
      ],
      "@spyne-console/design-system/icons": [
        "./vendor-settings/design-system/icons/index.js"
      ],
      "@spyne-console/design-system/icons/urls": [
        "./vendor-settings/design-system/icons/urls.js"
      ],
      "@spyne-console/design-system/logo": [
        "./vendor-settings/design-system/logo/index.jsx"
      ],
      "@spyne-console/design-system/filter-chip": [
        "./vendor-settings/design-system/filter-chip/filter-chip.jsx"
      ],
      "@spyne-console/design-system/search-bar": [
        "./vendor-settings/design-system/search-bar/search-bar.jsx"
      ],
      "@spyne-console/design-system/filter-chips": [
        "./vendor-settings/design-system/filter-chip/filter-chips.jsx"
      ],
      "@spyne-console/design-system/date-picker/date-range-picker": [
        "./vendor-settings/design-system/date-picker/date-range-picker.jsx"
      ],
      "@spyne-console/design-system/radio-button": [
        "./vendor-settings/design-system/radio-button/radio-button.jsx"
      ],
      "@spyne-console/design-system/dialog": [
        "./vendor-settings/design-system/dialog-modal/Dialog.js"
      ],
      "@spyne-console/design-system/charts/gauge-chart": [
        "./vendor-settings/design-system/charts/gauge-chart.jsx"
      ],
      "@spyne-console/design-system/modal/modal-wrapper": [
        "./vendor-settings/design-system/modal/modal-wrapper.jsx"
      ],
