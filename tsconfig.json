{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@spyne-console/store": [
        "./vendor-settings/store-shim.ts"
      ],
      "@spyne-console/design-system": [
        "./vendor-settings/design-system/index.ts"
      ],
      "@spyne-console/design-system/accordian": [
        "./vendor-settings/design-system/accordian/accordian.jsx"
      ],
      "@spyne-console/design-system/button": [
        "./vendor-settings/design-system/button/button.jsx"
      ],
      "@spyne-console/design-system/input-field": [
        "./vendor-settings/design-system/input-field/input-field.jsx"
      ],
      "@spyne-console/design-system/phone-input-field": [
        "./vendor-settings/design-system/input-field/phone-input-field.jsx"
      ],
      "@spyne-console/design-system/checkbox": [
        "./vendor-settings/design-system/checkbox/checkbox.jsx"
      ],
      "@spyne-console/design-system/toggle": [
        "./vendor-settings/design-system/toggle/toggle.jsx"
      ],
      "@spyne-console/design-system/spinner": [
        "./vendor-settings/design-system/spinner/spinner.jsx"
      ],
      "@spyne-console/design-system/slider": [
        "./vendor-settings/design-system/slider/slider.jsx"
      ],
      "@spyne-console/design-system/skeleton": [
        "./vendor-settings/design-system/skeleton/skeleton.jsx"
      ],
      "@spyne-console/design-system/modal": [
        "./vendor-settings/design-system/modal/modal.jsx"
      ],
      "@spyne-console/design-system/tooltip": [
        "./vendor-settings/design-system/tooltip/tooltip.jsx"
      ],
      "@spyne-console/design-system/dropdown": [
        "./vendor-settings/design-system/dropdown/dropdown.jsx"
      ],
      "@spyne-console/design-system/dropdown/select-dropdown": [
        "./vendor-settings/design-system/dropdown/select-dropdown/select-dropdown.jsx"
      ],
      "@spyne-console/design-system/dropdown/checkbox-dropdown": [
        "./vendor-settings/design-system/dropdown/checkbox-dropdown/checkbox-dropdown.jsx"
      ],
      "@spyne-console/design-system/dropdown/date-picker-dropdown": [
